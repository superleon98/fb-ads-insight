# ============================================
# FB 广告洞察系统 - 环境变量配置
# ============================================

# 后端服务端口
PORT=3001
NODE_ENV=production

# CORS 配置（填写你的前端域名，多个用逗号分隔）
# 如果用 docker-compose，保持默认即可
CORS_ORIGIN=*

# ============================================
# 1. AdLibrary.com API（必填）
# 注册: https://adlibrary.com → 升级到 Business 计划 → Developer Dashboard 创建 API Key
# ============================================
ADLIBRARY_API_KEY=你的_adlibrary_api_key
ADLIBRARY_BASE_URL=https://adlibrary.com/api

# ============================================
# 2. Kimi AI API（必填，用于 AI 分析功能）
# 注册: https://platform.moonshot.cn → 创建 API Key
# ============================================
KIMI_API_KEY=你的_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k

# ============================================
# 3. 飞书 SSO（可选，不用则 AI 分析不强制登录）
# 注册: https://open.feishu.cn → 创建企业自建应用
# ============================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 飞书回调地址需与飞书开放平台设置一致
FEISHU_REDIRECT_URI=http://你的服务器IP/login/callback

# ============================================
# 系统性能配置
# ============================================
CACHE_TTL_MS=300000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
